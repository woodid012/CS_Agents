# Copy this to .env.local and fill in your values
# Add the same variables to your Vercel project: Settings → Environment Variables

# Neon PostgreSQL connection string
# Get this from: neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic API key (for AI agents — add when ready)
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Microsoft Entra ID login (Auth.js) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
# Azure Portal → Entra ID → App registrations → CS Capital CRM
AUTH_MICROSOFT_ENTRA_ID_ID=          # Application (client) ID
AUTH_MICROSOFT_ENTRA_ID_SECRET=      # Client secret VALUE (not the secret ID)
# Replace <tenant-id> with your Directory (tenant) ID
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
# On Vercel: add all four above in Settings → Environment Variables (Production + Preview).
# Auth.js auto-detects the URL on Vercel, so no AUTH_URL is needed for production.
