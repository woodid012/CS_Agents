# Copy this to .env.local and fill in your values
# Add the same variables to your Vercel project: Settings → Environment Variables

# Neon PostgreSQL connection string
# Get this from: neon.tech → your project → Connection Details → Connection string
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Anthropic API key (for AI agents — add when ready)
# Get this from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
